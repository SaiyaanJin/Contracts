# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-very-long-random-secret-key
API_PREFIX=/api/v1

# Database (PostgreSQL recommended, MongoDB supported)
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://clm_user:clm_password@localhost:5432/grid_clm
# For MongoDB: mongodb://localhost:27017/grid_clm

# JWT
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# File Storage
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800

# Email (Exchange)
MAIL_SERVER=mail.grid-india.in
MAIL_USERNAME=nldc\\erldcnotifications
MAIL_PASSWORD=your-mail-password-here
MAIL_FROM=erldcnotifications@grid-india.in
MAIL_DOMAIN=nldc

# SSO (External)
SSO_VERIFY_URL=https://sso.erldc.in:5000/verify
SSO_EMP_DATA_URL=https://sso.erldc.in:5000/emp_data

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3004

# Portal URL
PORTAL_URL=https://sso.erldc.in:3000

# AI (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
